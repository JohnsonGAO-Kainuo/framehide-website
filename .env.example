# Contact form email delivery.
# The form uses Resend directly from /api/contact.
# Add these values in Vercel Project Settings -> Environment Variables.

RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@framehide.com

# Must be a verified sender/domain in Resend for production delivery.
# Example after domain verification:
# CONTACT_FROM_EMAIL=FrameHide <hello@framehide.com>
CONTACT_FROM_EMAIL=FrameHide <onboarding@resend.dev>
